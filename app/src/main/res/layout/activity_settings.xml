<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:tag="themeCard"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Settings"
                android:tag="themeText"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/jetbrains_mono_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:text="Server port"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="Port"
                android:inputType="number"
                android:maxLines="1"
                android:text="1390"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:text="@string/auth_hint"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etAuthUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="@string/auth_user_hint"
                android:inputType="text"
                android:autofillHints="username"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <EditText
                android:id="@+id/etAuthPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="@string/auth_pass_hint"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <Button
                android:id="@+id/btnChangeFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_teal_button"
                android:tag="themeAccent"
                android:fontFamily="@font/jetbrains_mono_bold"
                android:minHeight="46dp"
                android:text="📁 Change folder"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:fontFamily="@font/jetbrains_mono_regular" />

            <Button
                android:id="@+id/btnEnableHotspot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_teal_button"
                android:tag="themeAccent"
                android:fontFamily="@font/jetbrains_mono_bold"
                android:minHeight="46dp"
                android:text="Hotspot settings"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnCheckUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_teal_button"
                android:tag="themeAccent"
                android:fontFamily="@font/jetbrains_mono_bold"
                android:minHeight="46dp"
                android:text="⬇️ Check for updates"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:text="App theme"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnThemeLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button"
                    android:tag="themeAccent"
                    android:fontFamily="@font/jetbrains_mono_bold"
                    android:minHeight="46dp"
                    android:text="☀️ Light"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btnThemeDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_primary_button"
                    android:tag="themeAccent"
                    android:fontFamily="@font/jetbrains_mono_bold"
                    android:minHeight="46dp"
                    android:text="🌙 Dark"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:text="Custom colors (hex, e.g. #d57455)"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etThemeAccent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="Accent (#d57455)"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <EditText
                android:id="@+id/etThemeBg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="Background (#f9f1ec)"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <EditText
                android:id="@+id/etThemeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:fontFamily="@font/jetbrains_mono_regular"
                android:hint="Text (#1e1e1d)"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnThemeApply"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button"
                    android:tag="themeAccent"
                    android:fontFamily="@font/jetbrains_mono_bold"
                    android:minHeight="46dp"
                    android:text="Apply theme"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btnThemeReset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_teal_button"
                    android:tag="themeAccent"
                    android:fontFamily="@font/jetbrains_mono_bold"
                    android:minHeight="46dp"
                    android:text="Reset"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnGithub"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="14dp"
                android:layout_gravity="center_horizontal"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:contentDescription="GitHub"
                android:src="@drawable/ic_github" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
